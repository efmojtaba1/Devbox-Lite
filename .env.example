# ==========================
# DevBox Lite Configuration
# ==========================
# Copy this file to .env and customize as needed.

# === Project Settings ===
PROJECT_NAME=devbox-lite
TZ=Asia/Tehran

# === Tool Versions ===
# Change these to pin specific versions. Use 'latest' for newest stable.

# Languages
PHP_VERSION=8.4
NODE_VERSION=22
PYTHON_VERSION=3.12

# Package Managers
COMPOSER_VERSION=latest
BUN_VERSION=latest
PNPM_VERSION=latest

# Frameworks
LARAVEL_VERSION=latest

# Testing
PEST_VERSION=latest

# === Database Settings ===
# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=app

# PostgreSQL
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# === Port Settings ===
MYSQL_PORT=3307
POSTGRES_PORT=5433
REDIS_PORT=6380
