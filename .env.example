# ==========================
# DevBox Lite Configuration
# ==========================
# Copy this file to .env and customize as needed.

# === Project Settings ===
PROJECT_NAME=devbox-lite
TZ=Asia/Tehran

# === Workspace Path ===
# Windows (slow - bind mount through Docker Desktop):
#   WORKSPACE_PATH=../../
# WSL2 (fast - native Linux filesystem):
#   WORKSPACE_PATH=~/projects/DevBox_Lite
#   or: WORKSPACE_PATH=/home/youruser/projects/DevBox_Lite
WORKSPACE_PATH=../../

# === Tool Versions ===
# Pin specific versions here for reproducible builds.

# Languages
PHP_VERSION=8.4
NODE_VERSION=22
PYTHON_VERSION=3.12

# Package Managers
COMPOSER_VERSION=2.8.8
BUN_VERSION=1.2.17
PNPM_VERSION=9.15.9

# Frameworks
LARAVEL_VERSION=latest

# Testing
PEST_VERSION=latest

# === Database Settings ===
# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=app

# PostgreSQL
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# === Port Settings ===
MYSQL_PORT=3307
POSTGRES_PORT=5433
REDIS_PORT=6380
MONGO_PORT=27017
MARIADB_PORT=3308
MEMCACHED_PORT=11211
