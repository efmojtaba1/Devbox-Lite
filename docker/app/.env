# ==========================
# DevBox Lite - Tool Versions
# ==========================
# Focused on: Laravel, Next.js, React, Python
# All tools use latest stable version by default.
# Change these values to pin specific versions.

# === Languages ===
PHP_VERSION=8.4
NODE_VERSION=22
PYTHON_VERSION=3.12

# === Package Managers ===
COMPOSER_VERSION=latest
BUN_VERSION=latest
PNPM_VERSION=latest

# === Frameworks ===
LARAVEL_VERSION=latest

# === Testing ===
PEST_VERSION=latest

# ==========================
# Ubuntu
# ==========================
UBUNTU_VERSION=24.04

# ==========================
# Timezone
# ==========================
TZ=Asia/Tehran
